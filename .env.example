# MQTT Configuration
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

# Model Configuration
MODEL_PATH=models/earthquake_model.tflite
MODEL_THRESHOLD=0.7
DETECTION_SENSITIVITY=1.0

# Sensor Configuration
SENSOR_SAMPLE_RATE=100
SENSOR_IDS=SENSOR001,SENSOR002,SENSOR003
BUFFER_SIZE=512

# Alert Configuration
ALERT_ENABLED=true
ALERT_THRESHOLD=5.0
ALERT_EMAIL=admin@example.com

# Application Configuration
LOG_LEVEL=INFO
LOG_DIR=logs
DEBUG=false

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Database Configuration
DATABASE_URL=sqlite:///earthquake.db
BACKUP_ENABLED=true
BACKUP_INTERVAL=3600

# Monitoring
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
